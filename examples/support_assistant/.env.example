# Copy to .env (or export these) to customize. Every var is optional —
# with none set, the example runs fully offline on the demo provider.

# Use a real model (gpt-4o-mini) and OpenAI embeddings instead of the demo
# backends. When unset, the bundled offline demo provider is used.
# OPENAI_API_KEY=sk-...

# Require a Bearer token on every route except /health and the model-list routes
# (/v1/models and the bare /models). Multiple keys: AUTH_API_KEY=key-a,key-b
# AUTH_API_KEY=dev-secret

# Point the OrdersConnector at a real orders service. When unset, order lookups
# use a small in-memory fixture so the example runs with no backend.
# ORDERS_API_URL=https://orders.internal.acme.com
# ORDERS_API_TOKEN=service-token

# HTTP port for `python main.py` (default 8000).
# PORT=8000
